## Backend (Node.js)
# Used by `backend/src/index.js`
PORT=5000

## MongoDB Atlas (cloud) — REQUIRED
## Example:
## MONGO_URI="mongodb+srv://USER:PASSWORD@CLUSTER_HOST/wallet-sync?retryWrites=true&w=majority"
MONGO_URI=

PYTHON_SERVER_URL=http://python-server:8000

## Python server (FastAPI)
# Used by `python-server/app/config/settings.py`
DB_NAME=wallet-sync

## Optional external API keys (leave blank to start containers)
GOLDRUSH_API_KEY=
TATUM_API_KEY=

## Optional (used if/when auth is added)
JWT_SECRET=dev-secret-change-me

## Frontend (baked at build time by Vite)
VITE_API_URL=http://localhost:5000
